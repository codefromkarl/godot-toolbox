          "path": "godot_toolbox/save_core/enabled",
          "value": true
        }
      ],
      "input_map": [],
      "verification": [
        "scripts/verify_game_architecture_packs.sh"
      ],
      "godot_version": {
        "min": "4.6"
      },
      "selection_rationale": "自研 versioned snapshot/save-slot 边界，参考 SaveState/GDQuest/Godot 文档但不保存任意 scene tree。"
    },
    {
      "id": "flow-test-kit",
      "kind": "architecture-test-kit",
      "default": false,
      "plugins": [],
