      "input_map": [],
      "verification": [
        "scripts/verify_game_architecture_packs.sh"
      ],
      "godot_version": {
        "min": "4.6"
      },
      "selection_rationale": "自研 flow smoke fixture，给 mode transition 与 result payload 提供可复用验证入口。"
    }
