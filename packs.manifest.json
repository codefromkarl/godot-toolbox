      "input_map": [],
      "verification": [],
      "godot_version": {
        "min": "4.6"
      },
      "selection_rationale": "调试价值高，但主要作用于开发阶段，不应默认进入所有项目",
      "when_to_enable": [
        "项目 heavily uses signals",
        "需要可视化 signal flow 调试"
      ]
    },
