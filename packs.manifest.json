        "scripts/verify_game_architecture_packs.sh"
      ],
      "godot_version": {
        "min": "4.6"
      },
      "selection_rationale": "自研稳定 tick/time-scale 边界，避免把长生命周期模拟塞进任意 Node 生命周期。"
    },
    {
      "id": "data-core",
      "kind": "architecture-core",
      "default": false,
      "plugins": [],
