      "project_settings": [
        {
          "path": "godot_toolbox/flow_core/enabled",
          "value": true
        }
      ],
      "input_map": [],
      "verification": [
        "scripts/verify_game_architecture_packs.sh"
      ],
      "godot_version": {
        "min": "4.6"
      },
      "selection_rationale": "自研复杂游戏 flow spine，提供 GameMode、FlowRequest、FlowResult 与 pause/result 边界。"
    },
    {
      "id": "simulation-core",
      "kind": "architecture-core",
      "default": false,
      "plugins": [],
      "tooling": [],
