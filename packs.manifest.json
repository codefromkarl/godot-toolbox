      ],
      "project_settings": [
        {
          "path": "godot_toolbox/data_core/enabled",
          "value": true
        }
      ],
      "input_map": [],
      "verification": [
        "scripts/verify_game_architecture_packs.sh"
      ],
      "godot_version": {
        "min": "4.6"
      },
      "selection_rationale": "自研轻量 data registry 与稳定 ID 合约，吸收 Resource/Pandora 思路但不变成 RPG 数据库。"
    },
    {
      "id": "save-core",
      "kind": "architecture-core",
      "default": false,
      "plugins": [],
      "tooling": [],
      "requires": [
        "base",
        "data-core"
      ],
      "conflicts": [],
      "autoloads": [
        {
          "name": "SaveCore",
          "path": "res://addons/godot_toolbox_architecture/save_core/save_core.gd",
