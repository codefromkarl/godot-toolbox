{
  "schema_version": 2,
  "toolbox_identity": {
    "name": "godot-toolbox",
    "kind": "ai-native-godot-bootstrap-control-plane"
  },
  "selection_axes": [
    "automation_value",
    "reuse_breadth",
    "domain_coupling",
    "maintenance_cost",
    "truth_boundary_risk"
  ],
  "pack_contract": {
    "required_fields": [
      "requires",
      "conflicts",
      "autoloads",
      "project_settings",
      "input_map",
      "verification",
      "godot_version"
    ],
    "owned_truth": [
      "flow contracts",
      "state boundaries",
      "save contracts",
      "data ID contracts",
      "verification contracts"
    ]
  },
  "base_template": {
    "path": "templates/base",
    "default_enabled_plugins": [
      "gdUnit4"
    ],
    "default_tooling": [
      "godot-gdscript-toolkit"
    ],
    "verification": [
      "templates/base/scripts/gdscript_toolkit_check.sh",
      "templates/base/scripts/gdscript_toolkit_format.sh",
      "templates/base/scripts/gdunit4_smoke.sh"
    ]
  },
  "packs": [
    {
      "id": "base",
      "kind": "baseline",
      "default": true,
      "plugins": [
        "gdUnit4"
      ],
      "tooling": [
        "godot-gdscript-toolkit"
      ],
      "requires": [],
      "conflicts": [],
      "autoloads": [],
      "project_settings": [
        {
          "path": "godot_toolbox/base/enabled",
          "value": true
        }
      ],
      "input_map": [],
      "verification": [
        "templates/base/scripts/gdunit4_smoke.sh"
      ],
      "godot_version": {
        "min": "4.6"
      },
      "selection_rationale": "高自动化价值、低领域耦合、适合作为 Day 0 基线"
    },
    {
      "id": "validation",
      "kind": "optional-pack",
      "default": false,
      "plugins": [
        "godot_doctor"
      ],
      "tooling": [],
      "requires": [
        "base"
      ],
      "conflicts": [],
      "autoloads": [],
      "project_settings": [
        {
          "path": "godot_toolbox/validation/enabled",
          "value": true
        }
      ],
      "input_map": [],
      "verification": [],
      "godot_version": {
        "min": "4.6"
      },
      "selection_rationale": "把资源与场景约束变成可执行校验，适合需要 contract 的项目",
      "when_to_enable": [
        "需要把场景或资源规则纳入 CI",
        "需要 repo-owned validation suite"
      ]
    },
    {
      "id": "debug",
