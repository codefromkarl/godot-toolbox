        "base"
      ],
      "conflicts": [],
      "autoloads": [],
      "project_settings": [
        {
          "path": "godot_toolbox/juice/enabled",
          "value": true
        }
      ],
      "input_map": [],
      "verification": [],
      "godot_version": {
        "min": "4.6"
      },
      "selection_rationale": "表现层价值明显，但属于特定主题能力",
      "when_to_enable": [
        "需要快速建立 game-feel 工作流",
        "项目重视反馈 authoring 与表现迭代"
      ]
    },
    {
      "id": "flow-core",
      "kind": "architecture-core",
      "default": false,
      "plugins": [],
