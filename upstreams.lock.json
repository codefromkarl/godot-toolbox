{
  "schema_version": 1,
  "cache_dir": ".cache/upstreams",
  "entries": [
    {
      "id": "godot-gdscript-toolkit",
      "kind": "tooling",
      "source": {
        "type": "git",
        "url": "https://github.com/Scony/godot-gdscript-toolkit",
        "version": "4.5.0"
      },
      "integration": {
        "mode": "tool-only",
        "targets": [
          "pyproject.toml",
          "templates/base/pyproject.toml",
          "templates/base/scripts/gdscript_toolkit_check.sh",
          "templates/base/scripts/gdscript_toolkit_format.sh"
        ]
      },
      "patches": []
    },
    {
